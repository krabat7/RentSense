u0440\u0432\u0430\u043d\u0442\u0435\u0441\u0430", "\u0443\u043b\u0438\u0446\u0430 \u0441\u0435\u0440\u0433\u0435\u044f \u043c\u0430\u043a\u0435\u0435\u0432\u0430", "\u0443\u043b\u0438\u0446\u0430 \u0441\u0435\u0440\u0433\u0435\u044f \u044d\u0439\u0437\u0435\u043d\u0448\u0442\u0435\u0439\u043d\u0430", "\u0443\u043b\u0438\u0446\u0430 \u0441\u0435\u0440\u0433\u0438\u044f \u0440\u0430\u0434\u043e\u043d\u0435\u0436\u0441\u043a\u043e\u0433\u043e", "\u0443\u043b\u0438\u0446\u0430 \u0441\u0435\u0440\u0435\u0433\u0438\u043d\u0430", "\u0443\u043b\u0438\u0446\u0430 \u0441\u0435\u0440\u043f\u0443\u0445\u043e\u0432\u0441\u043a\u0438\u0439 \u0432\u0430\u043b", "\u0443\u043b\u0438\u0446\u0430 \u0441\u0438\u043c\u043e\u043d\u043e\u0432\u0441\u043a\u0438\u0439 \u0432\u0430\u043b", "\u0443\u043b\u0438\u0446\u0430 \u0441\u0438\u043c\u0444\u0435\u0440\u043e\u043f\u043e\u043b\u044c\u0441\u043a\u0430\u044f", "\u0443\u043b\u0438\u0446\u0430 \u0441\u043a\u0443\u043b\u044c\u043f\u0442\u043e\u0440\u0430 \u043c\u0443\u0445\u0438\u043d\u043e\u0439", "\u0443\u043b\u0438\u0446\u0430 \u0441\u043e\u0432\u0435\u0442\u0441\u043a\u043e\u0439 \u0430\u0440\u043c\u0438\u0438", "\u0443\u043b\u0438\u0446\u0430 \u0441\u043e\u043a\u043e\u043b\u044c\u043d\u0438\u0447\u0435\u0441\u043a\u0438\u0439 \u0432\u0430\u043b", "\u0443\u043b\u0438\u0446\u0430 \u0441\u043e\u043b\u043d\u0435\u0447\u043d\u0430\u044f", "\u0443\u043b\u0438\u0446\u0430 \u0441\u043e\u043b\u044f\u043d\u043a\u0430", "\u0443\u043b\u0438\u0446\u0430 \u0441\u043e\u0441\u0435\u043d\u0441\u043a\u0438\u0439 \u0441\u0442\u0430\u043d", "\u0443\u043b\u0438\u0446\u0430 \u0441\u043e\u0444\u044c\u0438 \u043a\u043e\u0432\u0430\u043b\u0435\u0432\u0441\u043a\u043e\u0439", "\u0443\u043b\u0438\u0446\u0430 \u0441\u043e\u0447\u0438\u043d\u0441\u043a\u0430\u044f", "\u0443\u043b\u0438\u0446\u0430 \u0441\u043f\u0438\u0440\u0438\u0434\u043e\u043d\u043e\u0432\u043a\u0430", "\u0443\u043b\u0438\u0446\u0430 \u0441\u043f\u043e\u0440\u0442\u0438\u0432\u043d\u0430\u044f", "