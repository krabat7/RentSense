[flake8]
max-line-length = 127
exclude = 
    .git,
    __pycache__,
    .venv,
    venv,
    env,
    .env,
    build,
    dist,
    *.egg-info,
    .pytest_cache,
    .mypy_cache,
    mlruns,
    mlflow.db,
    catboost_info
# E203: whitespace before ':' (black compat)
# E501: line length (black)
# W503: line break before binary operator (black compat)
ignore =
    E203,
    E501,
    W503,
max-complexity = 10
per-file-ignores =
    __init__.py:F401

